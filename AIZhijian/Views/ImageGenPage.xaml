<UserControl x:Class="AIZhijian.Views.ImageGenPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="🖼️ GPT-Image-2 图片生成" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <Border Background="#F9F9F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PresetBox" Grid.Column="0" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" Margin="0,0,8,0"
                                  SelectionChanged="PresetBox_SelectionChanged"/>
                        <Button x:Name="SavePresetBtn" Grid.Column="1" Content="保存预设"
                                Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,6,0"
                                Click="SavePreset_Click"/>
                        <Button x:Name="DeletePresetBtn" Grid.Column="2" Content="删除"
                                Style="{StaticResource SecondaryButton}" Width="60"
                                Click="DeletePreset_Click" IsEnabled="False"/>
                    </Grid>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="SingleModeRadio" Content="单条生成" IsChecked="True"
                                 GroupName="ImageGenMode" FontWeight="SemiBold" Margin="0,0,16,0"
                                 Checked="ModeRadio_Checked"/>
                    <RadioButton x:Name="BatchModeRadio" Content="批量生成"
                                 GroupName="ImageGenMode" FontWeight="SemiBold"
                                 Checked="ModeRadio_Checked"/>
                </StackPanel>

                <TextBlock Text="提示词" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="PromptBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,4"
                         TextChanged="PromptBox_TextChanged"/>

                <TextBlock x:Name="BatchCountText" Visibility="Collapsed"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,12"/>

                <Border x:Name="CostBanner" Visibility="Collapsed"
                        Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1"
                        CornerRadius="4" Padding="10" Margin="0,0,0,12">
                    <TextBlock x:Name="CostText" TextWrapping="Wrap"/>
                </Border>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="参考图片 (最多10张，可选)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="选择图片..." Style="{StaticResource SecondaryButton}" Width="120"
                                Click="PickImages_Click"/>
                        <Button x:Name="ClearImagesBtn" Content="清除" Style="{StaticResource SecondaryButton}"
                                Width="60" Margin="8,0,0,0" Click="ClearImages_Click" IsEnabled="False"/>
                    </StackPanel>
                    <WrapPanel x:Name="ImagesPanel" Margin="0,6,0,0"/>
                </StackPanel>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="渠道" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ChannelBox" SelectedIndex="0">
                            <ComboBoxItem Content="官方 (official)" Tag="official"/>
                            <ComboBoxItem Content="低价 (budget)" Tag="budget"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="画幅" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="AspectRatioBox" SelectedIndex="1">
                            <ComboBoxItem Content="1:1" Tag="1:1"/>
                            <ComboBoxItem Content="9:16" Tag="9:16"/>
                            <ComboBoxItem Content="16:9" Tag="16:9"/>
                            <ComboBoxItem Content="2:3" Tag="2:3"/>
                            <ComboBoxItem Content="3:2" Tag="3:2"/>
                            <ComboBoxItem Content="4:3" Tag="4:3"/>
                            <ComboBoxItem Content="3:4" Tag="3:4"/>
                            <ComboBoxItem Content="4:5" Tag="4:5"/>
                            <ComboBoxItem Content="5:4" Tag="5:4"/>
                            <ComboBoxItem Content="21:9" Tag="21:9"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="分辨率" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ResolutionBox" SelectedIndex="1">
                            <ComboBoxItem Content="1K" Tag="1k"/>
                            <ComboBoxItem Content="2K" Tag="2k"/>
                            <ComboBoxItem Content="4K" Tag="4k"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="质量" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="QualityBox" SelectedIndex="1">
                            <ComboBoxItem Content="低" Tag="low"/>
                            <ComboBoxItem Content="中" Tag="medium"/>
                            <ComboBoxItem Content="高" Tag="high"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="PhotoRealCheck" Content="真实照片模式 (PhotoReal)" Margin="0,0,0,16"/>

                <TextBlock x:Name="StatusText" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <Button x:Name="GenerateBtn" Content="生成图片" Style="{StaticResource PrimaryButton}"
                        Height="36" Width="140" Click="GenerateBtn_Click"/>
            </StackPanel>
        </Border>

        <Border x:Name="ResultsPanel" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="生成结果" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel x:Name="ResultsList"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
