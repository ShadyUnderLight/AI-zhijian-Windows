<UserControl x:Class="AIZhijian.Views.SeedancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="🎬 Seedance 视频生成" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <Border Background="#F9F9F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PresetBox" Grid.Column="0" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" Margin="0,0,8,0"
                                  SelectionChanged="PresetBox_SelectionChanged"/>
                        <Button x:Name="SavePresetBtn" Grid.Column="1" Content="保存预设"
                                Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,6,0"
                                Click="SavePreset_Click"/>
                        <Button x:Name="DeletePresetBtn" Grid.Column="2" Content="删除"
                                Style="{StaticResource SecondaryButton}" Width="60"
                                Click="DeletePreset_Click" IsEnabled="False"/>
                    </Grid>
                </Border>
                <TextBlock Text="提示词" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="PromptBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="模式" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ModeBox" SelectedIndex="0">
                            <ComboBoxItem Content="参考生视频" Tag="reference"/>
                            <ComboBoxItem Content="首尾帧" Tag="first_last"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="模型" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ModelBox" SelectedIndex="0">
                            <ComboBoxItem Content="Seedance 2.0" Tag="dreamina-seedance-2-0-260128"/>
                            <ComboBoxItem Content="Seedance 2.0 Fast" Tag="dreamina-seedance-2-0-fast-260128"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="比例" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="RatioBox" SelectedIndex="0">
                            <ComboBoxItem Content="自适应" Tag="adaptive"/>
                            <ComboBoxItem Content="9:16" Tag="9:16"/>
                            <ComboBoxItem Content="16:9" Tag="16:9"/>
                            <ComboBoxItem Content="4:3" Tag="4:3"/>
                            <ComboBoxItem Content="1:1" Tag="1:1"/>
                            <ComboBoxItem Content="3:4" Tag="3:4"/>
                            <ComboBoxItem Content="21:9" Tag="21:9"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="分辨率" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ResolutionBox" SelectedIndex="1">
                            <ComboBoxItem Content="480p" Tag="480p"/>
                            <ComboBoxItem Content="720p" Tag="720p"/>
                            <ComboBoxItem Content="1080p" Tag="1080p"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="时长 (秒)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="DurationBox" Text="5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="数量 (1-4)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="CountBox" Text="1"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="AudioCheck" Content="生成音频" IsChecked="True" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="素材 (图片/视频)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Button Content="选择素材..." Style="{StaticResource SecondaryButton}" Width="120"
                            Click="PickAssets_Click"/>
                    <StackPanel x:Name="AssetsPanel" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="虚拟人素材库" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="AssetConfigText" Text="素材库未加载" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>
                        <ProgressBar x:Name="AssetLoadingBar" Height="4" IsIndeterminate="True"
                                     Visibility="Collapsed" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="AssetGroupBox" Grid.Column="0" DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id" Margin="0,0,8,0"
                                      SelectionChanged="AssetGroupBox_SelectionChanged"/>
                            <Button x:Name="RefreshGroupsBtn" Grid.Column="1" Content="刷新" Width="60"
                                    Style="{StaticResource SecondaryButton}" Click="RefreshGroups_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewGroupBox" Grid.Column="0" Text="" Margin="0,0,8,0"/>
                            <Button x:Name="CreateGroupBtn" Grid.Column="1" Content="新建组" Width="60"
                                    Style="{StaticResource SecondaryButton}" Click="CreateGroup_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ImportNameBox" Grid.Column="0" Text="" Margin="0,0,8,0"/>
                            <Button x:Name="ImportAssetBtn" Grid.Column="1" Content="导入素材" Width="80"
                                    Style="{StaticResource SecondaryButton}" Click="ImportAsset_Click"/>
                        </Grid>

                        <TextBlock x:Name="AssetErrorText" FontSize="12" Foreground="{StaticResource DangerBrush}"
                                   Visibility="Collapsed" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="AssetItemsControl" Visibility="Collapsed" Margin="0,0,0,4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,8"
                                            Width="140">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                       TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding LastStatus}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                            <Button Content="加入参考" FontSize="11" Height="24"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Tag="{Binding}"
                                                    Click="AddVirtualAsset_Click"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="StatusText" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <Button x:Name="GenerateBtn" Content="生成视频" Style="{StaticResource PrimaryButton}"
                        Height="36" Width="140" Click="GenerateBtn_Click"/>
            </StackPanel>
        </Border>

        <Border x:Name="ResultPanel" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="结果" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock x:Name="ResultLink" Cursor="Hand" TextDecorations="Underline"
                           Foreground="Blue" MouseLeftButtonDown="ResultLink_MouseDown"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
