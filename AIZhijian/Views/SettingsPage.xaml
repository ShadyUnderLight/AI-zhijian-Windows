<UserControl x:Class="AIZhijian.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="⚙ 设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="API 服务器地址" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="修改后需要重新登录" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UrlBox" Grid.Column="0" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="修改" Style="{StaticResource PrimaryButton}"
                            Width="80" Click="ChangeUrl_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="并发数" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="同时提交的任务数量 (1-5)" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="ConcurrencyBox" Width="60" Text="3"/>
                    <Button Content="保存" Style="{StaticResource PrimaryButton}" Width="60"
                            Margin="8,0,0,0" Click="SaveConcurrency_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="关于" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="AI 智剪 Windows 版 v1.0.0" FontSize="13"/>
                <TextBlock Text="基于原项目 AI-zhijian (macOS/SwiftUI) 移植" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0"/>
                <TextBlock Text="开源协议: MIT" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
