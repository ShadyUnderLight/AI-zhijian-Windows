<UserControl x:Class="AIZhijian.Views.TaskListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="⏳ 任务队列" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Grid Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PauseBtn" Content="⏸ 暂停" Style="{StaticResource SecondaryButton}"
                        Click="PauseBtn_Click" Width="80" Margin="0,0,8,0"/>
                <Button x:Name="ClearCompletedBtn" Content="清除已完成" Style="{StaticResource SecondaryButton}"
                        Click="ClearCompleted_Click" Margin="0,0,8,0"/>
                <Button x:Name="ClearFailedBtn" Content="清除失败" Style="{StaticResource SecondaryButton}"
                        Click="ClearFailed_Click" Margin="0,0,8,0"/>
                <Button Content="全部取消" Style="{StaticResource SecondaryButton}"
                        Click="CancelAll_Click" Foreground="{StaticResource DangerBrush}"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="StatsText" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
            <ItemsControl x:Name="BatchContainer">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="12">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="{Binding ChevronText}"
                                            Style="{StaticResource SecondaryButton}"
                                            Width="24" Height="24" Padding="0" FontSize="10"
                                            Visibility="{Binding BatchId, Converter={StaticResource NullToVisibility}}"
                                            Tag="{Binding BatchId}"
                                            Click="Chevron_Click"/>

                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                               FontWeight="Bold" FontSize="14"
                                               VerticalAlignment="Center" Margin="4,0,0,0"
                                               Tag="{Binding BatchId}"
                                               MouseDown="BatchTitle_MouseDown"/>

                                    <Border Grid.Column="2"
                                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}}"
                                            Background="#FFF0E0" CornerRadius="4" Padding="4,1" Margin="6,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="⏸ 已暂停" FontSize="11" Foreground="#CC6600"/>
                                    </Border>

                                    <TextBlock Grid.Column="3" Text="{Binding StatusLabelText}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="12" VerticalAlignment="Center"
                                               Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>

                                    <Button Grid.Column="4" Content="⋮"
                                            Style="{StaticResource SecondaryButton}"
                                            Width="28" Height="24" Padding="0" FontSize="16"
                                            Visibility="{Binding BatchId, Converter={StaticResource NullToVisibility}}"
                                            Tag="{Binding BatchId}"
                                            Click="BatchMenuButton_Click"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Items}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Kind}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Summary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Elapsed}" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                                                           Visibility="{Binding RetryCount, Converter={StaticResource PositiveIntToVisibility}}">
                                                    <Run Text="{Binding RetryCount, StringFormat='x{0}'}" />
                                                </TextBlock>
                                            <TextBlock Grid.Column="5" Text="{Binding ErrorMessage}" FontSize="12" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="120" Margin="0,0,4,0"/>
                                            <Button Grid.Column="6" Content="复制错误" FontSize="11"
                                                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibility}}"
                                                        Style="{StaticResource SecondaryButton}" Padding="6,1"
                                                        Click="CopyError_Click" Tag="{Binding Id}"/>
                                            <Button Grid.Column="7" Content="复制 Prompt" FontSize="11"
                                                        Visibility="{Binding Summary, Converter={StaticResource StringNotEmptyToVisibility}}"
                                                        Style="{StaticResource SecondaryButton}" Padding="6,1"
                                                        Click="CopyPrompt_Click" Tag="{Binding Id}"/>
                                            <StackPanel Grid.Column="8" Orientation="Horizontal">
                                                <Button Content="重试" FontSize="12"
                                                        Visibility="{Binding ShowRetry, Converter={StaticResource BoolToVisibility}}"
                                                        Style="{StaticResource SecondaryButton}" Padding="8,2"
                                                        Click="RetryItem_Click" Tag="{Binding Id}"/>
                                                <Button Content="去编辑" FontSize="12"
                                                        Visibility="{Binding ShowEdit, Converter={StaticResource BoolToVisibility}}"
                                                        Style="{StaticResource SecondaryButton}" Padding="8,2" Margin="4,0,0,0"
                                                        Click="EditInGenerator_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
