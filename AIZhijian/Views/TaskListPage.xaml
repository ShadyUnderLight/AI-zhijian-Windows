<UserControl x:Class="AIZhijian.Views.TaskListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="⏳ 任务队列" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Grid Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PauseBtn" Content="⏸ 暂停" Style="{StaticResource SecondaryButton}"
                        Click="PauseBtn_Click" Width="80" Margin="0,0,8,0"/>
                <Button x:Name="ClearCompletedBtn" Content="清除已完成" Style="{StaticResource SecondaryButton}"
                        Click="ClearCompleted_Click" Margin="0,0,8,0"/>
                <Button x:Name="ClearFailedBtn" Content="清除失败" Style="{StaticResource SecondaryButton}"
                        Click="ClearFailed_Click" Margin="0,0,8,0"/>
                <Button Content="全部取消" Style="{StaticResource SecondaryButton}"
                        Click="CancelAll_Click" Foreground="{StaticResource DangerBrush}"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="StatsText" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
            <ItemsControl x:Name="BatchContainer">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="12">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ItemCountText}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="{Binding PauseBtnText}" Style="{StaticResource SecondaryButton}"
                                                Click="BatchPauseResume_Click" Tag="{Binding BatchId}"
                                                Width="70" Margin="0,0,4,0" FontSize="12"/>
                                        <Button Content="✏ 重命名" Style="{StaticResource SecondaryButton}"
                                                Click="BatchRename_Click" Tag="{Binding BatchId}"
                                                FontSize="12" Margin="0,0,4,0"/>
                                        <Button Content="✕ 取消" Style="{StaticResource SecondaryButton}"
                                                Click="BatchCancel_Click" Tag="{Binding BatchId}"
                                                FontSize="12" Margin="0,0,4,0" Foreground="{StaticResource DangerBrush}"/>
                                        <Button Content="清除" Style="{StaticResource SecondaryButton}"
                                                Click="BatchClear_Click" Tag="{Binding BatchId}"
                                                FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Kind}" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Summary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Elapsed}" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" Text="{Binding ErrorMessage}" FontSize="12" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="200" Margin="0,0,8,0"/>
                                                <Button Grid.Column="5" Content="重试" FontSize="12"
                                                        Visibility="{Binding ShowRetry, Converter={StaticResource BoolToVisibility}}"
                                                        Style="{StaticResource SecondaryButton}" Padding="8,2"
                                                        Click="RetryItem_Click" Tag="{Binding Id}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</UserControl>
