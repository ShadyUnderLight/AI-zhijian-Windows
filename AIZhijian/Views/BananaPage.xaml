<UserControl x:Class="AIZhijian.Views.BananaPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="🍌 Banana 图片生成" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <Border Background="#F9F9F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PresetBox" Grid.Column="0" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" Margin="0,0,8,0"
                                  SelectionChanged="PresetBox_SelectionChanged"/>
                        <Button x:Name="SavePresetBtn" Grid.Column="1" Content="保存预设"
                                Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,6,0"
                                Click="SavePreset_Click"/>
                        <Button x:Name="DeletePresetBtn" Grid.Column="2" Content="删除"
                                Style="{StaticResource SecondaryButton}" Width="60"
                                Click="DeletePreset_Click" IsEnabled="False"/>
                    </Grid>
                </Border>
                <TextBlock Text="提示词" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="PromptBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="供应商" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ProviderBox" SelectedIndex="0" Width="200">
                        <ComboBoxItem Content="第三方 (third_party)" Tag="third_party"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="参考图片 (最多3张)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Button Content="选择图片..." Style="{StaticResource SecondaryButton}" Width="120"
                            Click="PickImages_Click"/>
                    <StackPanel x:Name="ImagesPanel" Margin="0,6,0,0"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <Button x:Name="GenerateBtn" Content="生成" Style="{StaticResource PrimaryButton}"
                        Height="36" Width="120" Click="GenerateBtn_Click"/>
            </StackPanel>
        </Border>

        <Border x:Name="ResultPanel" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="生成结果" FontWeight="Bold" Margin="0,0,0,8"/>
                <Image x:Name="ResultImage" Stretch="Uniform" MaxHeight="400"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
