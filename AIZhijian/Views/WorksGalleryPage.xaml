<UserControl x:Class="AIZhijian.Views.WorksGalleryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="🎨 作品画廊" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Grid Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="RefreshBtn" Content="刷新" Style="{StaticResource SecondaryButton}"
                        Click="Refresh_Click" Width="80" Margin="0,0,8,0"/>
                <Button x:Name="FavFilterBtn" Content="⭐ 仅收藏" Style="{StaticResource SecondaryButton}"
                        Click="FavFilter_Click" Width="90" Margin="0,0,8,0"/>
                <Button x:Name="ClearBtn" Content="清空全部" Style="{StaticResource SecondaryButton}"
                        Click="ClearAll_Click" Foreground="{StaticResource DangerBrush}"/>
            </StackPanel>
        </Grid>

        <ItemsControl x:Name="WorksItems">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <StackPanel>
                            <DockPanel>
                                <Button Content="{Binding FavoriteStar}" Width="32" Height="32"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        CommandParameter="{Binding Id}" Click="Favorite_Click"
                                        DockPanel.Dock="Right"/>
                                <TextBlock Text="{Binding Prompt}" FontWeight="SemiBold" TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
                                <Run Text="{Binding Kind, Mode=OneWay}"/><Run Text=" | "/>
                                <Run Text="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                       FontSize="12" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock x:Name="EmptyText" Text="暂无作品" Foreground="{StaticResource TextSecondary}"
                   HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed"/>
    </StackPanel>
</UserControl>
