<UserControl x:Class="AIZhijian.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380">
    <Border Style="{StaticResource CardBorder}" Margin="0,60,0,0">
        <StackPanel>
            <TextBlock Text="AI 智剪" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="海灵智剪 Windows 客户端" FontSize="13" Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <TextBlock Text="用户名" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox" Margin="0,0,0,12"/>

            <TextBlock Text="密码" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

            <CheckBox x:Name="RememberCheck" Content="记住登录信息" Margin="0,0,0,16"/>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                       Visibility="Collapsed" Margin="0,0,0,8"/>

            <Button x:Name="LoginButton" Content="登录" Style="{StaticResource PrimaryButton}"
                    Height="36" Click="LoginButton_Click"/>
            <TextBlock x:Name="LoadingText" Text="正在登录..." Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" Margin="0,8,0,0" Visibility="Collapsed"/>
            <TextBlock x:Name="HealthText" Text="" HorizontalAlignment="Center" FontSize="12"
                       Margin="0,12,0,0" Visibility="Visible"/>
        </StackPanel>
    </Border>
</UserControl>
