<Window x:Class="AIZhijian.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MinWidth="320" MaxWidth="500">
    <StackPanel Margin="16">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <TextBox x:Name="InputBox" Margin="0,0,0,12" Padding="8,6"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" IsDefault="True" Width="80" Height="32" Click="Ok_Click"
                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Width="80" Height="32"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </StackPanel>
</Window>
