<UserControl x:Class="AIZhijian.Views.VeoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="🌐 Veo 视频生成" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="渠道" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ChannelBox" SelectedIndex="0" SelectionChanged="ChannelChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0">
                        <TextBlock Text="模型" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ModelBox" SelectedIndex="0" SelectionChanged="ModelChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="6,0,0,0">
                        <TextBlock Text="模式" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ModeBox" SelectedIndex="0" SelectionChanged="ModeChanged"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="提示词" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="PromptBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0" x:Name="AspectRatioPanel">
                        <TextBlock Text="画幅" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="AspectRatioBox" SelectedIndex="1">
                            <ComboBoxItem Content="9:16" Tag="9:16"/><ComboBoxItem Content="16:9" Tag="16:9"/>
                            <ComboBoxItem Content="1:1" Tag="1:1"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="分辨率" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ResolutionBox" SelectedIndex="0"/>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="DurationPanel" Margin="0,0,0,12">
                    <TextBlock Text="时长" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="DurationBox" SelectedIndex="0" Width="150">
                        <ComboBoxItem Content="4s" Tag="4"/><ComboBoxItem Content="6s" Tag="6"/><ComboBoxItem Content="8s" Tag="8"/>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="AudioCheckBox" Content="生成音频" Margin="0,0,0,12"/>

                <StackPanel x:Name="NegPromptPanel" Margin="0,0,0,12">
                    <TextBlock Text="负面提示词" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="NegPromptBox" Height="40" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel x:Name="FilePanel" Margin="0,0,0,12">
                    <TextBlock Text="参考文件" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Button Content="选择文件..." Style="{StaticResource SecondaryButton}" Width="120"
                            Click="PickFiles_Click"/>
                    <StackPanel x:Name="FilesList" Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Button x:Name="GenerateBtn" Content="生成视频" Style="{StaticResource PrimaryButton}"
                        Height="36" Width="140" Click="GenerateBtn_Click"/>
            </StackPanel>
        </Border>

        <Border x:Name="ResultPanel" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="结果" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock x:Name="ResultLink" Cursor="Hand" TextDecorations="Underline"
                           Foreground="Blue" MouseLeftButtonDown="ResultLink_MouseDown"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
